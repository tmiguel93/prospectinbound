generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  ONE_TIME
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SELLER)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leads        Lead[]
}

model Partner {
  id        String    @id @default(cuid())
  name      String    @unique
  notes     String?
  active    Boolean   @default(true)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id                String             @id @default(cuid())
  partnerId         String
  pipelineId        String?
  name              String
  description       String?
  segment           String
  active            Boolean            @default(true)
  demoUrl           String?
  signupUrl         String?
  internalNotes     String?
  partner           Partner            @relation(fields: [partnerId], references: [id])
  pipeline          Pipeline?          @relation(fields: [pipelineId], references: [id])
  plans             Plan[]
  commissionRule    CommissionRule?
  questions         ProductQuestion[]
  leads             Lead[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([partnerId, name])
}

model Plan {
  id          String        @id @default(cuid())
  productId   String
  name        String
  priceCents  Int
  period      BillingPeriod @default(MONTHLY)
  description String?
  active      Boolean       @default(true)
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model CommissionRule {
  id                     String   @id @default(cuid())
  productId              String   @unique
  fixedActivationCents   Int      @default(0)
  recurringPercentageBps Int      @default(0)
  maxMonths              Int?
  unlimitedRecurrence    Boolean  @default(true)
  includeFirstPayment    Boolean  @default(true)
  safetyDays             Int      @default(0)
  refundPolicy           String?
  active                 Boolean  @default(true)
  product                Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Pipeline {
  id        String          @id @default(cuid())
  name      String          @unique
  archived  Boolean         @default(false)
  stages    PipelineStage[]
  products  Product[]
  leads     Lead[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model PipelineStage {
  id         String   @id @default(cuid())
  pipelineId String
  name       String
  color      String   @default("#0891b2")
  position   Int
  isInitial  Boolean  @default(false)
  isFinal    Boolean  @default(false)
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  leads      Lead[]

  @@unique([pipelineId, position])
}

model Lead {
  id                String              @id @default(cuid())
  establishmentName String
  contactName       String?
  phone             String?
  whatsapp          String?
  email             String?
  city              String?
  state             String?
  productId         String
  pipelineId        String
  stageId           String
  source            String              @default("Prospecção própria")
  ownerId           String?
  score             Int                 @default(0)
  priority          String              @default("Normal")
  nextAction        String?
  nextActionAt      DateTime?
  lastContactAt     DateTime?
  notes             String?
  status            String              @default("ACTIVE")
  product           Product             @relation(fields: [productId], references: [id])
  pipeline          Pipeline            @relation(fields: [pipelineId], references: [id])
  stage             PipelineStage       @relation(fields: [stageId], references: [id])
  owner             User?               @relation(fields: [ownerId], references: [id])
  activities        LeadActivity[]
  stageHistory      LeadStageHistory[]
  qualificationResponses LeadQualificationResponse[]
  meetings          Meeting[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model Meeting {
  id        String   @id @default(cuid())
  leadId    String
  title     String
  startsAt  DateTime
  endsAt    DateTime
  format    String
  link      String?
  location  String?
  notes     String?
  status    String   @default("SCHEDULED")
  result    String?
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadQualificationResponse {
  id         String   @id @default(cuid())
  leadId     String
  questionId String
  answerJson String
  points     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  question   ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([leadId, questionId])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  type      String
  content   String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadStageHistory {
  id          String   @id @default(cuid())
  leadId      String
  userId      String?
  previousId  String?
  nextId      String
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model ProductQuestion {
  id          String   @id @default(cuid())
  productId   String
  label       String
  inputType   String   @default("TEXT")
  optionsJson String?
  scoresJson  String?
  position    Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  responses   LeadQualificationResponse[]

  @@unique([productId, position])
}
